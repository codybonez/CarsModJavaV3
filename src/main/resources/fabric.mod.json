{
	"schemaVersion": 1,
	"id": "carsmod",
	"version": "${version}",
	"name": "CarsMod",
	"description": "Carsmod is a simple car mod which aims at creating faster transportation!",
	"authors": [
		"Me!"
	],
	"contact": {
		"homepage": "https://fabricmc.net/",
		"sources": "https://github.com/codybonez/CarsModJavaV3"
	},
	"license": "CC0-1.0",
	"icon": "assets/carsmod/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"production.carsmod.CarsMod",
			"production.carsmod.entities.CarModEntity",
			"production.carsmod.items.CarsModItems"
		],
		"fabric-datagen": [
			"production.carsmod.CarsModDataGenerator"
		],
		"client": [
			"production.carsmod.CarsModClient"
		]
	},
	"mixins": [
		"carsmod.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.2",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}